ORDER SUMMARY
=========================== -->

<div class="product-card" style="margin-top:30px;">

    <div class="product-content">

        <h2>

            Order Summary

        </h2>

        <br>

        <div class="product-meta">

            <span>Items Total</span>

            <span class="price" id="subTotal">

                ?0

