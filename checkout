<!-- ===========================
CHECKOUT
=========================== -->

<section class="featured-products">
<div class="product-card">

    <div class="product-content">

        <h2>

            Delivery Information

        </h2>

        <br>

        <form id="checkoutForm">

            <label>Full Name</label>

            <input type="text"
            placeholder="Enter your full name"
            style="width:100%;padding:14px;margin:8px 0 18px;border:1px solid #ddd;border-radius:8px;">

            <label>Mobile Number</label>

            <input type="tel"
            placeholder="Enter mobile number"
            style="width:100%;padding:14px;margin:8px 0 18px;border:1px solid #ddd;border-radius:8px;">

            <label>Email Address</label>

            <input type="email"
            placeholder="Enter email address"
            style="width:100%;padding:14px;margin:8px 0 18px;border:1px solid #ddd;border-radius:8px;">

            <label>Delivery Address</label>

            <textarea
            placeholder="House No, Street, Area..."
            rows="4"
            style="width:100%;padding:14px;margin:8px 0 18px;border:1px solid #ddd;border-radius:8px;resize:none;"></textarea>

            <div style="display:flex;gap:20px;flex-wrap:wrap;">

                <div style="flex:1;min-width:220px;">

                    <label>City</label>

                    <input type="text"
                    placeholder="Enter city"
                    style="width:100%;padding:14px;margin:8px 0 18px;border:1px solid #ddd;border-radius:8px;">

                </div>

                <div style="flex:1;min-width:220px;">

                    <label>Pincode</label>

                    <input type="number"
                    placeholder="Enter pincode"
                    style="width:100%;padding:14px;margin:8px 0 18px;border:1px solid #ddd;border-radius:8px;">

                </div>

            </div>

            <label>Order Notes (Optional)</label>

            <textarea
            placeholder="Any special delivery instructions..."
            rows="3"
            style="width:100%;padding:14px;margin:8px 0;border:1px solid #ddd;border-radius:8px;resize:none;"></textarea>

        </form>

    </div>

</div>
